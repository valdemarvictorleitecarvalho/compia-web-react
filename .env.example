# EmailJS (https://www.emailjs.com) — envio real de e-mails pelo frontend.
# Sem estas variáveis o sistema registra os e-mails como "SIMULADO" na Mensageria.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Mercado Pago — Checkout Transparente integrado direto no frontend.
# AVISO: expor o ACCESS_TOKEN no bundle é inseguro; aceito aqui por ser um
# projeto de demonstração sem backend. Sem as chaves, o pagamento é simulado.
VITE_MP_PUBLIC_KEY=
VITE_MP_ACCESS_TOKEN=

# SuperFrete (https://superfrete.com) — cotação real de PAC/SEDEX.
# Sem token (ou com a API fora do ar), usa a tabela de frete local.
VITE_SUPERFRETE_TOKEN=
